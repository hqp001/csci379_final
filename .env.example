# AI story generation (required)
OPENAI_API_KEY=sk-...

# Google OAuth — sign in with Google (required)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Transactional email via Resend — production only, not needed in dev
# RESEND_API_KEY=re_...

# Override default DB port (optional, default: 5433)
# DB_PORT=5433

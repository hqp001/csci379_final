<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="base-path" content={~p"/"} />
    <.live_title default="LearnAI" suffix=" · LearnAI">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
      (function() {
        var s = localStorage.getItem('theme');
        if (s === 'dark' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-200">
    <nav class="relative bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700">
      <div class="mx-auto flex h-16 max-w-7xl items-center gap-3 px-4 sm:px-6 lg:px-8">

        <%!-- Logo --%>
        <.link navigate={~p"/"} class="flex items-center gap-2.5 mr-auto min-w-0 shrink-0">
          <svg width="28" height="34" viewBox="0 0 28 34" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
            <path d="M14 0C6.268 0 0 6.268 0 14C0 24.5 14 34 14 34C14 34 28 24.5 28 14C28 6.268 21.732 0 14 0Z" fill="#4f46e5"/>
            <path d="M14 7L15.8 12.2H21.4L16.8 15.4L18.4 20.8L14 17.6L9.6 20.8L11.2 15.4L6.6 12.2H12.2L14 7Z" fill="#fbbf24"/>
          </svg>
          <span class="font-bold text-lg" style="font-family: 'Outfit', sans-serif;">
            <span class="text-slate-900 dark:text-white">Learn</span><span class="text-indigo-600">AI</span>
          </span>
        </.link>

        <%!-- Desktop unauthenticated links --%>
        <%= if !@current_scope do %>
          <div class="hidden sm:flex items-center gap-4">
            <.link href={~p"/users/register"} class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">{gettext("Register")}</.link>
            <.link href={~p"/users/log-in"} class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">{gettext("Log in")}</.link>
          </div>
        <% end %>

        <%!-- Language toggle (desktop) --%>
        <div class="hidden sm:flex items-center gap-1">
          <.link
            href={~p"/set-locale?locale=en"}
            class={[
              "rounded px-2 py-1 text-xs font-medium transition-colors",
              assigns[:locale] != "es" && "bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300",
              assigns[:locale] == "es" && "text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300"
            ]}
          >EN</.link>
          <.link
            href={~p"/set-locale?locale=es"}
            class={[
              "rounded px-2 py-1 text-xs font-medium transition-colors",
              assigns[:locale] == "es" && "bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300",
              assigns[:locale] != "es" && "text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300"
            ]}
          >ES</.link>
        </div>

        <%!-- Dark mode toggle --%>
        <button
          id="dark-mode-toggle"
          class="rounded-lg p-2 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors shrink-0"
          aria-label="Toggle dark mode"
        >
          <svg class="size-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="size-5 hidden dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>

        <%!-- User dropdown (desktop, authenticated) --%>
        <%= if @current_scope do %>
          <div class="relative hidden md:block" id="user-menu">
            <button
              phx-click={JS.toggle(
                to: "#user-dropdown",
                in: {"transition ease-out duration-200", "opacity-0 scale-95 -translate-y-1", "opacity-100 scale-100 translate-y-0"},
                out: {"transition ease-in duration-150", "opacity-100 scale-100 translate-y-0", "opacity-0 scale-95 -translate-y-1"}
              )}
              class="flex items-center gap-2 rounded-full pl-1 pr-2.5 py-1 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            >
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-900 text-xs font-bold text-indigo-600 dark:text-indigo-300 shrink-0">
                {String.first(String.upcase(@current_scope.user.email))}
              </span>
              <svg class="h-3 w-3 text-slate-400 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>

            <div
              id="user-dropdown"
              class="hidden absolute right-0 top-full mt-2 w-52 origin-top-right rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 shadow-lg py-1 z-50"
            >
              <div class="px-4 py-2.5 border-b border-slate-100 dark:border-slate-700">
                <p class="text-xs text-slate-500 dark:text-slate-400 truncate">{@current_scope.user.email}</p>
              </div>
              <.link navigate={~p"/dashboard"} class="flex items-center px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">{gettext("Dashboard")}</.link>
              <.link navigate={~p"/profile"} class="flex items-center px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">{gettext("Profile")}</.link>
              <.link href={~p"/users/settings"} class="flex items-center px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">{gettext("Settings")}</.link>
              <div class="border-t border-slate-100 dark:border-slate-700 my-1"></div>
              <.link href={~p"/users/log-out"} method="delete" class="flex items-center px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">{gettext("Log out")}</.link>
            </div>
          </div>

          <%!-- Mobile hamburger button --%>
          <button
            class="md:hidden rounded-lg p-2 text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors shrink-0"
            phx-click={JS.toggle(
              to: "#mobile-menu",
              in: {"transition-all ease-out duration-200", "opacity-0 -translate-y-2", "opacity-100 translate-y-0"},
              out: {"transition-all ease-in duration-150", "opacity-100 translate-y-0", "opacity-0 -translate-y-2"}
            )}
            aria-label="Open menu"
          >
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        <% else %>
          <%!-- Mobile unauthenticated links --%>
          <div class="sm:hidden flex items-center gap-2 shrink-0">
            <.link href={~p"/users/register"} class="text-xs font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">{gettext("Register")}</.link>
            <.link href={~p"/users/log-in"} class="text-xs font-medium text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors">{gettext("Log in")}</.link>
          </div>
        <% end %>
      </div>

      <%!-- Mobile slide-down menu (authenticated only) --%>
      <%= if @current_scope do %>
        <div
          id="mobile-menu"
          class="hidden md:hidden border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 space-y-1"
        >
          <p class="px-3 pb-1 text-xs font-medium text-slate-400 dark:text-slate-500 truncate">{@current_scope.user.email}</p>
          <.link navigate={~p"/dashboard"} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">{gettext("Dashboard")}</.link>
          <.link navigate={~p"/profile"} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">{gettext("Profile")}</.link>
          <.link href={~p"/users/settings"} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">{gettext("Settings")}</.link>
          <.link href={~p"/users/log-out"} method="delete" class="block rounded-lg px-3 py-2 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">{gettext("Log out")}</.link>
          <div class="pt-2 mt-2 border-t border-slate-200 dark:border-slate-700 flex items-center gap-2 px-3">
            <span class="text-xs text-slate-400 dark:text-slate-500">Lang:</span>
            <.link href={~p"/set-locale?locale=en"} class={["rounded px-2 py-1 text-xs font-medium transition-colors", assigns[:locale] != "es" && "bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300", assigns[:locale] == "es" && "text-slate-400 hover:text-slate-600"]}>EN</.link>
            <.link href={~p"/set-locale?locale=es"} class={["rounded px-2 py-1 text-xs font-medium transition-colors", assigns[:locale] == "es" && "bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300", assigns[:locale] != "es" && "text-slate-400 hover:text-slate-600"]}>ES</.link>
          </div>
        </div>
      <% end %>
    </nav>
    {@inner_content}
  </body>
</html>
